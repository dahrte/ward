{
  "name": "ward",
  "version": "0.0.0",
  "private": true,
  "description": "Vision denied. Spoilers concealed. Browse the web without accidentally discovering who won before you've watched the game.",
  "type": "module",
  "scripts": {
    "build": "wxt build -b firefox",
    "check": "vp check",
    "clean": "git clean -fdX .output .wxt node_modules",
    "compile": "vue-tsc --noEmit",
    "dev": "wxt -b firefox",
    "fix": "vp check --fix",
    "postinstall": "wxt prepare",
    "zip": "wxt zip -b firefox"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "4.2.1",
    "@hugeicons/vue": "1.0.6",
    "@vueuse/core": "14.3.0",
    "clsx": "2.1.1",
    "reka-ui": "2.10.0",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tw-animate-css": "1.4.0",
    "vue": "3.5.38"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@vue/tsconfig": "0.9.1",
    "@wxt-dev/module-vue": "1.0.3",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite-plus": "0.2.1",
    "vue-tsc": "3.3.5",
    "wxt": "0.20.26"
  },
  "packageManager": "pnpm@11.7.0"
}
